{
  "id": "advancedSearch",
  "name": "Wikist 高级搜索",
  "type": "search-engine",
  "version": "1.0.0",
  "source": "Wikist Core / MiniSearch-style field index",
  "repository": "https://github.com/lucaong/minisearch",
  "vendorDirectory": "minisearch",
  "description": "轻量高级搜索插件层，支持分页、字段权重、前缀匹配、模糊匹配、分类/质量/难度过滤。",
  "syntax": [
    "title:群 category:代数",
    "\"Lagrange theorem\" quality:A",
    "difficulty:本科 群论"
  ],
  "configKeys": [
    "enabled",
    "engine",
    "fuzzy",
    "prefix",
    "pageSize",
    "titleWeight",
    "summaryWeight",
    "bodyWeight",
    "categoryWeight"
  ],
  "hooks": ["search.enhance"],
  "permissions": ["search:enhance"],
  "defaultConfig": {
    "enabled": true,
    "engine": "wikist-mini",
    "fuzzy": true,
    "prefix": true,
    "pageSize": 10,
    "titleWeight": 9,
    "summaryWeight": 4,
    "bodyWeight": 1,
    "categoryWeight": 6
  },
  "entry": "core:advancedSearch",
  "license": "MIT-compatible"
}
